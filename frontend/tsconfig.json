{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "downlevelIteration": true,
    "paths": {
      "@/*": ["./*"],
      "next-auth/react": ["./src/compat/next-auth-react.tsx"],
      "next/navigation": ["./src/compat/next-navigation.ts"],
      "next/link": ["./src/compat/next-link.tsx"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "components/**/*.ts", "components/**/*.tsx", "lib/**/*.ts", "lib/**/*.tsx", "server/actions/**/*.ts", "app/globals.css"],
  "exclude": ["node_modules"]
}
