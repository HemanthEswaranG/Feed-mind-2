# FeedMind root environment variables (Next.js app)
# Copy this file to .env.local and replace values.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Prisma / PostgreSQL
# Example local URL: postgresql://postgres:postgres@localhost:5432/feedmind
DATABASE_URL=postgresql://username:password@localhost:5432/feedmind
DIRECT_URL=postgresql://username:password@localhost:5432/feedmind

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional AI providers (fill only what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
